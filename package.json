{
	"name": "@idleberg/yeoman-generator",
	"version": "0.2.0",
	"description": "An opinionated drop-in replacement for Yeoman generators, using modern libraries",
	"license": "MIT",
	"author": "Jan T. Sott",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/yeoman-generator.git"
	},
	"keywords": [
		"yeoman-generator",
		"clack-prompts",
		"clack",
		"eta",
		"yeoman"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"engines": {
		"node": ">=22.21.0"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "concurrently --prefix-colors blue,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze",
		"prepack": "npm run build",
		"publish:jsr": "deno publish",
		"publish:npm": "np",
		"test": "#vitest run"
	},
	"dependencies": {
		"@yeoman/adapter": "^4.0.2",
		"glob": "^13.0.6",
		"is-binary-path": "^3.0.0",
		"kleur": "^4.1.5",
		"mem-fs-editor": "^12.0.3",
		"yeoman-adapter-clack": "^0.3.0",
		"yeoman-environment": "^6.0.0",
		"yeoman-generator": "^8.1.2"
	},
	"devDependencies": {
		"@clack/prompts": "^1.1.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@idleberg/configs": "^0.4.2",
		"@types/node": "^24.12.0",
		"@vitest/coverage-v8": "^4.1.2",
		"concurrently": "^9.2.1",
		"np": "^11.0.2",
		"tsdown": "0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"peerDependencies": {
		"@clack/prompts": "^1.1.0",
		"eta": "^4.5.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
